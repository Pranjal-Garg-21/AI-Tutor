<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.quicinc.chatapp"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="31"
        android:targetSdkVersion="34" />

    <permission
        android:name="com.quicinc.chatapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.quicinc.chatapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:debuggable="true"
        android:extractNativeLibs="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ChatApp" >

        <!-- Main/Splash Activity - decides where to go -->
        <activity
            android:name="com.quicinc.chatapp.MainActivity"
            android:exported="true"
            android:noHistory="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name="com.quicinc.chatapp.LoginActivity"
            android:exported="false"
            android:noHistory="true" />

        <!-- Register Activity -->
        <activity
            android:name="com.quicinc.chatapp.RegisterActivity"
            android:exported="false" />

        <!-- Home Activity -->
        <activity
            android:name="com.quicinc.chatapp.HomeActivity"
            android:exported="false" />

        <!-- Conversation Activity (Chat/PDF) -->
        <activity
            android:name="com.quicinc.chatapp.Conversation"
            android:exported="false"
            android:parentActivityName="com.quicinc.chatapp.HomeActivity" />

        <!-- Quiz Activity -->
        <activity
            android:name="com.quicinc.chatapp.QuizActivity"
            android:exported="false"
            android:parentActivityName="com.quicinc.chatapp.HomeActivity" />

        <!-- Quiz History Activity -->
        <activity
            android:name="com.quicinc.chatapp.QuizHistoryActivity"
            android:exported="false"
            android:parentActivityName="com.quicinc.chatapp.HomeActivity" />

        <!-- Quiz Detail Activity -->
        <activity
            android:name="com.quicinc.chatapp.QuizDetailActivity"
            android:exported="false"
            android:parentActivityName="com.quicinc.chatapp.QuizHistoryActivity" />

        <!-- Flashcard Activities -->
        <activity
            android:name="com.quicinc.chatapp.FlashcardActivity"
            android:exported="false"
            android:parentActivityName="com.quicinc.chatapp.HomeActivity" />
        <activity
            android:name="com.quicinc.chatapp.FlashcardPdfGeneratorActivity"
            android:exported="false"
            android:parentActivityName="com.quicinc.chatapp.FlashcardActivity" />
        <activity
            android:name="com.quicinc.chatapp.CreateFlashcardSetActivity"
            android:exported="false"
            android:parentActivityName="com.quicinc.chatapp.FlashcardActivity" />
        <activity
            android:name="com.quicinc.chatapp.FlashcardStudyActivity"
            android:exported="false"
            android:parentActivityName="com.quicinc.chatapp.FlashcardActivity" />

        <!-- Create Gem Activity -->
        <activity
            android:name="com.quicinc.chatapp.CreateGemActivity"
            android:exported="false"
            android:parentActivityName="com.quicinc.chatapp.HomeActivity" />

        <uses-native-library
            android:name="libadsprpc.so"
            android:required="false" />
        <uses-native-library
            android:name="libcdsprpc.so"
            android:required="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.quicinc.chatapp.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>